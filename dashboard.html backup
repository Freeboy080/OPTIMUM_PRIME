<script>


const SUPABASE_URL = 'https://hpjztfiijgkkbexpxxqz.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imhwanp0Zmlpamdra2JleHB4eHF6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE2NTA4ODUsImV4cCI6MjA5NzIyNjg4NX0.LbS4fFhnFWBg3U2dqV6eVERbX-GG4d0oPk40XKkMLSA';
const supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

document.addEventListener('DOMContentLoaded', async () => {
  const { data: { session } } = await supabaseClient.auth.getSession();
  if (!session) {
    window.location.href = 'login.html';
    return;
  }



//Logs out when account deleted
supabaseClient.auth.onAuthStateChange((event, session) => {
  if (event === 'SIGNED_OUT' || !session) {
    window.location.href = 'login.html';
  }
});


const { data: profileData } = await supabaseClient
  .from('users')
  .select('display_name, discord_username, discord_role, avatar_url, twitter_username')
  .eq('id', session.user.id)
  .single();

if (profileData) {
  document.getElementById('nameField').textContent = profileData.display_name || session.user.user_metadata.display_name || '\u2014';
  document.getElementById('discordField').textContent = profileData.discord_username ? '@' + profileData.discord_username : '\u2014'
  document.getElementById('twitterField').textContent = profileData.twitter_username ? profileData.twitter_username : '\u2014';
  document.getElementById('discordRoleField').textContent = profileData.discord_role || '\u2014';
  document.getElementById('rankField').textContent = '\u2014';

  if (profileData.avatar_url) {
    const profilePic = document.getElementById('profilePic');
    if (profilePic) {
      profilePic.innerHTML = `<img src="${profileData.avatar_url}" style="width:100%; height:100%; object-fit:cover; border-radius:50%;">`;
    }
  }

}


});

// NAVBAR movements
function toggleMenu() {
  document.getElementById('sideMenu').classList.toggle('open');
  const overlay = document.getElementById('menuOverlay');
  overlay.style.display = overlay.style.display === 'block' ? 'none' : 'block';
}





//HQ banner live animation
const hqObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      document.getElementById('warriorHQ').style.opacity = '1';
      document.getElementById('warriorHQ').style.transform = 'translateX(0)';
      hqObserver.unobserve(entry.target);
    }
  });
}, { threshold: 0, rootMargin: '0px 0px 500px 0px' });

hqObserver.observe(document.getElementById('warriorHQ'));









supabaseClient.auth.getSession().then(({ data: { session } }) => {
  if (session) {
    // Replace login link with logout button in side menu
    const loginLink = document.querySelector('a[href="login.html"]');
    if (loginLink) {
      loginLink.textContent = 'LOGOUT';
      loginLink.href = '#';
      loginLink.onclick = async () => {
        await supabaseClient.auth.signOut();
        window.location.href = 'login.html';
      };
    }
  }
});


</script>


}





}


function createSparks(colors) {
  const box = document.querySelector('.box');
  for (let i = 0; i < 40; i++) {
    setTimeout(() => {
      const spark = document.createElement('div');
      spark.classList.add('spark');
      spark.style.left = Math.random() * 100 + '%';
      spark.style.bottom = Math.random() * 30 + '%';
      spark.style.background = colors[Math.floor(Math.random() * colors.length)];
      spark.style.width = Math.random() * 5 + 2 + 'px';
      spark.style.height = spark.style.width;
      box.appendChild(spark);
      setTimeout(() => spark.remove(), 1500);
    }, Math.random() * 1000);
  }
}





const stickers = [
  { id: 'wander1', size: 50 },
  { id: 'wander2', size: 200 },
  { id: 'wander3', size: 40 },
  { id: 'wander4', size: 120 },
  { id: 'wander5', size: 70 },
];

stickers.forEach(s => {
  const img = document.getElementById(s.id);
  let x = Math.random() * window.innerWidth;
  let y = Math.random() * window.innerHeight;
  let vx = (Math.random() - 0.5) * 1.5;
  let vy = (Math.random() - 0.5) * 1.5;

  function wander() {
    x += vx;
    y += vy;
    vx += (Math.random() - 0.5) * 0.1;
    vy += (Math.random() - 0.5) * 0.1;
    vx = Math.max(-2, Math.min(2, vx));
    vy = Math.max(-2, Math.min(2, vy));
    if (x < 0 || x > window.innerWidth - s.size) vx *= -1;
    if (y < 0 || y > window.innerHeight - s.size) vy *= -1;
    img.style.left = x + 'px';
    img.style.top = y + 'px';
    requestAnimationFrame(wander);
  }
  wander();
});





const revealCards = document.querySelectorAll('.revealCard');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.style.opacity = '1';
      entry.target.style.transform = 'translateY(0)';
    } else {
      entry.target.style.opacity = '0';
      entry.target.style.transform = 'translateY(60px)';
    }
  });
}, { threshold: 0.2 });

revealCards.forEach(card => observer.observe(card));




const revealOnScroll = document.querySelectorAll('#creatorCard, #optimumGroup');
window.addEventListener('scroll', () => {
  revealOnScroll.forEach(el => {
    const rect = el.getBoundingClientRect();
    if (rect.top < window.innerHeight * 0.9) {
      el.style.opacity = '1';
      el.style.transform = el.style.transform.replace('translateY(60px)', 'translateY(0)');
    } else {
      el.style.opacity = '0';
      el.style.transform = el.style.transform.replace('translateY(0)', 'translateY(60px)');
    }
  });
});



const ecosystemLine = document.getElementById('ecosystemLine');
const ecosystemObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      ecosystemLine.style.width = '80%';
    } else {
      ecosystemLine.style.width = '0%';
    }
  });
}, { threshold: 0.5 });

ecosystemObserver.observe(ecosystemLine);
  </script>












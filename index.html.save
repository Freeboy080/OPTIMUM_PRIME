  <head>


<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
    <title>UNDER CONSTRUCTION...</title>
    <style>



    body {
  background: linear-gradient(180deg, #B0B4BE 0%, #E8EAF0 50%, #F5F5F5 80%, #1a1a1a 100%);
  min-height: 100vh;
}





  .box {
  background: linear-gradient(145deg, #ffffff, #E8EAF0);
  border-radius: 16px;
  padding: 20px;
  width: 95%;
  margin: 20px auto;
  backdrop-filter: blur(10px);
}




     @keyframes ninjaFire {
  0%, 100% { box-shadow: 0 0 10px 2px #9B30FF, 0 0 20px 5px #6A0DAD, 0 0 30px 8px #4B0082; }
  50% { box-shadow: 0 0 20px 5px #6A0DAD, 0 0 40px 10px #4B0082, 0 0 50px 15px #2E0057; }
}
@keyframes samuraiFire {
  0%, 100% { box-shadow: 0 0 10px 2px #FFB300, 0 0 20px 5px #FF6600, 0 0 30px 8px #FF2200; }
  50% { box-shadow: 0 0 20px 5px #FF6600, 0 0 40px 10px #FF2200, 0 0 50px 15px #CC0000; }
}
@keyframes vikingFire {
  0%, 100% { box-shadow: 0 0 10px 2px #00BFFF, 0 0 20px 5px #005F8A, 0 0 30px 8px #001F3F; }
  50% { box-shadow: 0 0 20px 5px #005F8A, 0 0 40px 10px #001F3F, 0 0 50px 15px #000D1A; }
}
@keyframes spartanFire {
  0%, 100% { box-shadow: 0 0 10px 2px #FFD700, 0 0 20px 5px #FF8C00, 0 0 30px 8px #FF6000; }
  50% { box-shadow: 0 0 20px 5px #FF8C00, 0 0 40px 10px #FF6000, 0 0 50px 15px #CC4400; }
}




@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}






.box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
background: linear-gradient(
  to bottom,
  rgba(0,0,0,0.15) 0%,
  transparent 20%,
  transparent 80%,
  rgba(0,0,0,0.15) 100%
);
  z-index: 2;
  pointer-events: none;
}



@keyframes floatSpark {
  0% { transform: translateY(0); opacity: 1; }
  100% { transform: translateY(-150px); opacity: 0; }
}
.spark {
  position: absolute;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: orange;
  animation: floatSpark 1.5s ease-out forwards;
  z-index: 3;
  pointer-events: none;
}





.warCard {
  width: 140px;
  height: 180px;
  background: #1a1a1a;
  border: 2px solid;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  animation: cardPulse 2s infinite;
  transition: transform 0.2s;
}
.warCard:active {
  transform: scale(0.95);
}
.warCardInner {
  text-align: center;
  padding: 10px;
}
.warCardName {
  font-size: 1.3em;
  font-weight: bold;
  margin: 0;
  letter-spacing: 2px;
}
.warCardSub {
  font-size: 0.8em;
  margin-top: 8px;
}
@keyframes cardPulse {
  0%, 100% { box-shadow: 0 0 10px currentColor; }
  50% { box-shadow: 0 0 25px currentColor; }
}





.stoneCard {
  width: 280px;
  height: 150px;
  background: white;
  border: 2px solid black;
  border-radius: 0px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4px 10px rgba(0,0,0,0.2);
  animation: stonePulse 2s infinite;
  transition: transform 0.2s;
}
.stoneCard:active {
  transform: scale(0.95);
}
.stoneCrack {
  position: absolute;
  top: 0;
  left: 50%;
  width: 2px;
  height: 100%;
  background: var(--glowColor);
  opacity: 0.6;
  clip-path: polygon(40% 0%, 60% 0%, 55% 30%, 70% 30%, 45% 60%, 60% 60%, 30% 100%, 50% 100%);
}
.stoneName {
  font-size: 1.5em;
  font-weight: bold;
  color: black;
  letter-spacing: 3px;
  margin: 0;
  position: relative;
  z-index: 1;
}
.stoneClass {
  font-size: 0.8em;
  color: #888;
  margin-top: 8px;
  letter-spacing: 1px;
  position: relative;
  z-index: 1;
}

@keyframes stonePulse {
  0%, 100% { box-shadow: 0 4px 10px rgba(0,0,0,0.2); }
  50% { box-shadow: 0 8px 20px rgba(0,0,0,0.3); }
}





#wanderSticker {
  position: fixed;
  width: 80px;
  z-index: 999;
  pointer-events: none;
}



#poseImg {
  width: 100vw;
  height: 100vh;
  object-fit: cover;
  display: block;
  margin: 0;
}





body {
  font-family: 'Inter', sans-serif;
}



#characterImg {
  filter: drop-shadow(0px 20px 15px rgba(0,0,0,0.3));
}


#creatorCard {
  font-family: 'Orbitron', sans-serif;
}

#optimumCard {
  font-family: 'Orbitron', sans-serif;
}



@keyframes fadeInLayer {
  from { opacity: 0; }
  to { opacity: 0.4; }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(80px); }
  to { opacity: 1; transform: translateY(0); }
}



@keyframes lineSlide {
  from { width: 0%; }
  to { width: 80%; }
}



#ecosystemLine {
  height: 2px;
  background: linear-gradient(to right, transparent, #1a1a1a, transparent);
  width: 0%;
  margin: 16px auto 0;
  transition: width 1.5s ease;
}




@keyframes flowDown {
  0% { background-position: 0 0; }
  100% { background-position: 0 100px; }
}
.connectionLine {
  width: 2px;
  height: 80px;
  background: repeating-linear-gradient(
    to bottom,
    #1a1a1a 0px,
    #1a1a1a 10px,
    transparent 10px,
    transparent 20px
  );
  background-size: 2px 20px;
  animation: flowDown 1s linear infinite;
  margin: 0 auto;
}


    </style>


  <script>
   let currentCharacter = '';
   document.body.style.overflow = 'hidden';



function changeCharacter(imageSrc, videoSrc, sparkColors, poseImgSrc, poseName, bgImg, pageLayerSrc, btnImg) {
  // Do nothing if same character already selected
  if (currentCharacter === imageSrc) return;
  currentCharacter = imageSrc;

  const img = document.getElementById('characterImg');
  const video = document.getElementById('fireVideo');
  const source = document.getElementById('fireSource');
  const content = document.getElementById('dashContent');

  // Hide everything first
  img.style.display = 'none';
  img.style.animation = '';
  content.style.animation = '';
  content.style.opacity = '0';

  // Play video
  source.src = videoSrc;
  video.style.display = 'block';
  video.load();
  video.play();

  document.getElementById('citizenDiv').style.display = 'none';
document.getElementById('dashboardBox').style.display = 'flex';


  document.getElementById('chooseTitle').style.display = 'none';
document.getElementById('chooseLine').style.display = 'none';
document.getElementById('chooseButtons').style.display = 'none';


